# ── Supabase ────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────────
# Find these in Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create two products in Stripe Dashboard:
#   1. Forma Pro Monthly  → $14.99/month
#   2. Forma Pro Yearly   → $99/year
# Then paste the Price IDs here:
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Webhook secret — from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
